[Unit]
Description=Johan - PiCortex Developer Agent
After=network.target docker.service
Requires=docker.service

[Service]
Type=simple
User=george
WorkingDirectory=/home/george/workspace/george/tick
ExecStart=/usr/bin/npx tsx src/index.ts run --agent agents/johan --daemon
Restart=always
RestartSec=10
EnvironmentFile=/home/george/workspace/george/tick/.env
StandardOutput=journal
StandardError=journal
SyslogIdentifier=johan

[Install]
WantedBy=multi-user.target
